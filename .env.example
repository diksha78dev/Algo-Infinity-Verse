# ── Required ──────────────────────────────────────────────────────────────
SESSION_SECRET=replace-with-a-long-random-secret
PASSWORD_PEPPER=replace-with-a-long-random-string

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
HOST=127.0.0.1

# ── CSRF Protection ───────────────────────────────────────────────────────
# Used to sign CSRF tokens. If omitted, a hardcoded fallback is used
# (acceptable for dev but set a unique value in production).
CSRF_SALT=replace-with-a-random-string

# ── Firebase Web SDK (public — used client-side for Google sign-in) ───────
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── Firebase Admin SDK (server-side — required for Firestore persistence) ──
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Optional / External APIs ──────────────────────────────────────────────
# Code execution (Judge0 / JDOODLE)
JDOODLE_CLIENT_ID=
JDOODLE_CLIENT_SECRET=
# AI features
GEMINI_API_KEY=